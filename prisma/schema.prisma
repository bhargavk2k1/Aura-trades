generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  emailVerified Boolean  @default(false)
  kycStatus     String   @default("pending")   // "pending" | "approved" | "rejected"
  kycSubmittedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  verificationTokens EmailVerificationToken[]
  watchlist          WatchlistItem[]
  preferences        UserPreferences?
  account            UserAccount?
  savedCards         SavedCard[]
  bankAccounts       BankAccount[]
  paymentOtps        PaymentOtp[]
}

// Tracks each user's real cash balance held by Aura Trade (BD)
model UserAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  cashBalance  Float    @default(0)
  reservedCash Float    @default(0)   // locked in open orders
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FundTransaction[]
}

model FundTransaction {
  id          String   @id @default(cuid())
  accountId   String
  type        String   // "deposit" | "withdrawal" | "trade_debit" | "trade_credit"
  amount      Float
  balanceAfter Float
  status      String   @default("completed") // "pending" | "completed" | "failed"
  reference   String   @default("")          // bank ref, ACH trace ID, order ID
  note        String   @default("")
  createdAt   DateTime @default(now())

  account UserAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  userId      String
  symbol      String
  listIndex   Int      @default(0)
  addedAt     DateTime @default(now())
  priceAtAdd  Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listIndex, symbol])
  @@index([userId])
}

// Bank account linked via ACH / micro-deposit verification
model BankAccount {
  id             String   @id @default(cuid())
  userId         String
  bankName       String
  accountType    String   // "checking" | "savings"
  last4          String
  routingNumber  String
  nickname       String   @default("")
  status         String   @default("pending_verification") // "pending_verification" | "verified" | "rejected"
  microDeposit1  Float?
  microDeposit2  Float?
  verifyAttempts Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Saved payment cards for deposits / withdrawals
model SavedCard {
  id              String   @id @default(cuid())
  userId          String
  cardholderName  String
  last4           String
  cardType        String   // "visa" | "mastercard" | "amex" | "discover"
  expiryMonth     Int
  expiryYear      Int
  nickname        String   @default("")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One-time passwords for payment confirmation
model PaymentOtp {
  id        String   @id @default(cuid())
  userId    String
  code      String
  purpose   String   // "deposit" | "withdrawal"
  amount    Float
  meta      String   @default("") // JSON: cardId / bankAccountId / method
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("light")
  watchlistNames  String   @default("")   // JSON: string[10]
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
